# ════════════════════════════════════════════════════════════
# QuantBot Infra — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════════════

# ── Mode ──
TRADING_MODE=simulation          # simulation | paper | live
LOG_LEVEL=INFO

# ── Hyperliquid API ──
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_TESTNET=true         # true for testnet, false for mainnet

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quantbot
POSTGRES_USER=quantbot_user
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── JWT / Auth ──
JWT_SECRET_KEY=change_me_jwt_secret_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ── API Encryption ──
ENCRYPTION_KEY=change_me_32_byte_aes_encryption_key

# ── Service Ports (internal) ──
BACKEND_API_PORT=8000
STRATEGY_ENGINE_PORT=8001
QUANT_RESEARCH_PORT=8002
ML_ENGINE_PORT=8003
MONITORING_PORT=8004
FRONTEND_PORT=3000

# ── Nginx ──
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
DOMAIN_NAME=localhost

# ── Risk Limits ──
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_POSITION_SIZE_PCT=0.10
MAX_PORTFOLIO_EXPOSURE_PCT=0.30
MAX_CONSECUTIVE_LOSSES=5
RISK_PER_TRADE_PCT=0.02

# ── Strategy Defaults ──
EMA_FAST=21
EMA_MEDIUM=34
EMA_SLOW=90
ATR_PERIOD=14
RSI_PERIOD=14

# ── Monitoring ──
HEALTH_CHECK_INTERVAL_SEC=30
LOG_RETENTION_DAYS=90
